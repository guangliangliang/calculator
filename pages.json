{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "行业计算器",
        "navigationBarBackgroundColor": "#E8EEF5",
        "navigationBarTextStyle": "black",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/industry-list/index",
      "style": {
        "navigationBarTitleText": "计算器列表",
        "navigationBarBackgroundColor": "#E8EEF5",
        "navigationBarTextStyle": "black"
      }
    },
    {
      "path": "pages/calculator/index",
      "style": {
        "navigationBarTitleText": "计算器",
        "navigationBarBackgroundColor": "#E8EEF5",
        "navigationBarTextStyle": "black"
      }
    },
    {
      "path": "pages/schedule-detail/index",
      "style": {
        "navigationBarTitleText": "还款明细",
        "navigationBarBackgroundColor": "#E8EEF5",
        "navigationBarTextStyle": "black"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "行业计算器",
    "navigationBarBackgroundColor": "#E8EEF5",
    "backgroundColor": "#E8EEF5"
  }
}
